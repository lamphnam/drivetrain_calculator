{
  "info": {
    "_postman_id": "7b6f3adb-3ea1-4f5c-8df3-2db7b4e1fd41",
    "name": "Drivetrain Calculator - Module 1 & Module 3",
    "description": "Postman collection for the current Spring Boot backend implementation of Module 1 and Module 3.\n\nRecommended execution order:\n1. Module 1 / Calculate - Save Module 1 Case\n2. Module 1 / Get Reference Values\n3. Module 3 / Get Gear Materials\n4. Module 3 / Calculate - Inherit Values From Module 1\n5. Module 3 / Get Saved Module 3 Result\n\nThe collection uses collection variables. Update {{baseUrl}} if your backend is running on a different host or port.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Module 1",
      "description": "Endpoints for motor selection, ratio distribution, shaft-state calculation, and saved-calculation history.",
      "item": [
        {
          "name": "Calculate - Save Module 1 Case",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var json = pm.response.json();",
                  "",
                  "if (json.caseInfo && json.caseInfo.designCaseId) {",
                  "    pm.collectionVariables.set('designCaseId', String(json.caseInfo.designCaseId));",
                  "}",
                  "",
                  "if (json.resultInfo && json.resultInfo.resultId) {",
                  "    pm.collectionVariables.set('module1ResultId', String(json.resultInfo.resultId));",
                  "}",
                  "",
                  "pm.test('designCaseId was captured', function () {",
                  "    pm.expect(pm.collectionVariables.get('designCaseId')).to.not.eql('');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"requiredPowerKw\": {{requiredPowerKw}},\n  \"requiredOutputRpm\": {{requiredOutputRpm}},\n  \"caseCode\": \"{{caseCode}}\",\n  \"caseName\": \"{{caseName}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/module-1/calculate",
            "description": "Creates or recalculates a saved Module 1 design case. The test script stores designCaseId and module1ResultId into collection variables."
          },
          "response": []
        },
        {
          "name": "Get Reference Values",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/module-1/reference-values",
            "description": "Gets default Module 1 reference values: active constant set, active motor count, default ratios, and default overall efficiency."
          },
          "response": []
        },
        {
          "name": "Get Module 1 History List",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/module-1/history",
            "description": "Lists saved Module 1 calculations."
          },
          "response": []
        },
        {
          "name": "Get Saved Module 1 Result",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/module-1/history/{{designCaseId}}",
            "description": "Reopens one saved Module 1 calculation using the collection variable {{designCaseId}}."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Module 3",
      "description": "Endpoints for bevel-gear material lookup, Module 3 calculation, and saved Module 3 result retrieval.",
      "item": [
        {
          "name": "Get Gear Materials",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var data = pm.response.json();",
                  "",
                  "pm.test('Materials list is not empty', function () {",
                  "    pm.expect(Array.isArray(data) && data.length > 0).to.eql(true);",
                  "});",
                  "",
                  "var preferred = Array.isArray(data)",
                  "    ? (data.find(function (item) { return item.materialCode === 'C40XH_QT'; }) || data[0])",
                  "    : null;",
                  "",
                  "if (preferred && preferred.materialId) {",
                  "    pm.collectionVariables.set('materialId', String(preferred.materialId));",
                  "}",
                  "",
                  "pm.test('materialId was captured', function () {",
                  "    pm.expect(pm.collectionVariables.get('materialId')).to.not.eql('');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/module-3/materials",
            "description": "Gets the available gear materials. The test script automatically stores the preferred materialId (C40XH_QT if present, otherwise the first item) into collection variables."
          },
          "response": []
        },
        {
          "name": "Calculate - Inherit Values From Module 1",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var json = pm.response.json();",
                  "",
                  "if (json.caseInfo && json.caseInfo.designCaseId) {",
                  "    pm.collectionVariables.set('designCaseId', String(json.caseInfo.designCaseId));",
                  "}",
                  "",
                  "if (json.resultInfo && json.resultInfo.resultId) {",
                  "    pm.collectionVariables.set('module3ResultId', String(json.resultInfo.resultId));",
                  "}",
                  "",
                  "pm.test('Module 3 response has shaft forces', function () {",
                  "    pm.expect(Array.isArray(json.shaftForces)).to.eql(true);",
                  "    pm.expect(json.shaftForces.length).to.be.above(0);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"designCaseId\": {{designCaseId}},\n  \"materialId\": {{materialId}}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/module-3/calculate",
            "description": "Calculates Module 3 by inheriting T1, n1, and U2 from the saved Module 1 result. Run the Module 1 calculate request and Get Gear Materials first so {{designCaseId}} and {{materialId}} are available."
          },
          "response": []
        },
        {
          "name": "Calculate - Override Inputs",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var json = pm.response.json();",
                  "",
                  "if (json.resultInfo && json.resultInfo.resultId) {",
                  "    pm.collectionVariables.set('module3ResultId', String(json.resultInfo.resultId));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"designCaseId\": {{designCaseId}},\n  \"inputT1Nmm\": {{overrideT1Nmm}},\n  \"inputN1Rpm\": {{overrideN1Rpm}},\n  \"inputU2\": {{overrideU2}},\n  \"serviceLifeHours\": {{serviceLifeHours}},\n  \"materialId\": {{materialId}}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/module-3/calculate",
            "description": "Calculates Module 3 using explicit request overrides for torque, speed, ratio, and service life. Useful for testcase validation and comparison against inherited-mode output."
          },
          "response": []
        },
        {
          "name": "Get Saved Module 3 Result",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/module-3/history/{{designCaseId}}",
            "description": "Reopens one saved Module 3 result using {{designCaseId}}."
          },
          "response": []
        }
      ]
    }
  ],
